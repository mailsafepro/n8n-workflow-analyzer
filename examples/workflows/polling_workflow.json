{
  "id": "2",
  "name": "Polling Workflow",
  "active": true,
  "nodes": [
    {
      "id": "node-1",
      "name": "Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 5 }] } },
      "position": [0, 0]
    },
    {
      "id": "node-2",
      "name": "HTTP Request",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": { "url": "https://api.example.com/data", "options": {} },
      "position": [200, 0]
    },
    {
      "id": "node-3",
      "name": "Set",
      "type": "n8n-nodes-base.set",
      "parameters": { "values": { "string": [{ "name": "result", "value": "={{$json}}" }] } },
      "position": [400, 0]
    }
  ],
  "connections": {
    "Schedule": { "main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]] },
    "HTTP Request": { "main": [[{ "node": "Set", "type": "main", "index": 0 }]] }
  },
  "settings": {}
}
