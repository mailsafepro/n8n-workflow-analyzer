{
  "id": "3",
  "name": "Loop HTTP Workflow",
  "active": true,
  "nodes": [
    {
      "id": "node-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": { "path": "loop-test" },
      "position": [0, 0]
    },
    {
      "id": "node-2",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "parameters": { "batchSize": 10 },
      "position": [200, 0]
    },
    {
      "id": "node-3",
      "name": "HTTP Request per item",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": { "url": "https://api.example.com/process", "options": {} },
      "position": [400, 0]
    },
    {
      "id": "node-4",
      "name": "Postgres",
      "type": "n8n-nodes-base.postgres",
      "parameters": { "operation": "insert", "table": "results" },
      "position": [600, 0]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]] },
    "Split In Batches": { "main": [[{ "node": "HTTP Request per item", "type": "main", "index": 0 }]] },
    "HTTP Request per item": { "main": [[{ "node": "Postgres", "type": "main", "index": 0 }]] }
  },
  "settings": {}
}
