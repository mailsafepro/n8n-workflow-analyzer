{
  "id": "wf-cred",
  "name": "Workflow with Credentials",
  "active": true,
  "nodes": [
    {
      "id": "n1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": { "path": "secure" },
      "position": [0, 0]
    },
    {
      "id": "n2",
      "name": "Postgres DB",
      "type": "n8n-nodes-base.postgres",
      "parameters": { "operation": "select", "table": "users" },
      "position": [200, 0],
      "credentials": {
        "postgres": {
          "id": "cred-123",
          "name": "Production DB"
        }
      }
    },
    {
      "id": "n3",
      "name": "Slack Notify",
      "type": "n8n-nodes-base.slack",
      "parameters": { "channel": "alerts" },
      "position": [400, 0],
      "credentials": {
        "slackApi": {
          "id": "cred-456",
          "name": "Workspace Token"
        }
      }
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Postgres DB", "type": "main", "index": 0 }]] },
    "Postgres DB": { "main": [[{ "node": "Slack Notify", "type": "main", "index": 0 }]] }
  },
  "settings": {},
  "tags": [{ "name": "production" }, { "name": "critical" }]
}
